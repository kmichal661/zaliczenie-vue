{
  "compilerOptions": {
    "rootDirs": ["src"],
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["es2023"],
    "target": "es2023",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
